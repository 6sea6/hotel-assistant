{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": false,
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "skipLibCheck": true
  },
  "include": [
    "src/shared/contracts.js",
    "src/**/*.d.ts",
    "src/renderer/app.module.js",
