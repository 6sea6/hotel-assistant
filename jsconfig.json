    "src/renderer/modules/about-manual.js",
    "src/renderer/modules/custom-select.js",
    "src/renderer/modules/ui-utils.js",
    "src/renderer/modules/dom-helpers.js",
    "src/renderer/modules/render-scheduler.js",
    "src/renderer/modules/window-controls.js",
    "src/renderer/modules/ranking-image.js",
    "src/renderer/modules/notification.js",
    "src/renderer/modules/perf.js",
    "src/main/hotel-storage.js",
    "src/renderer/modules/state.js",
    "src/renderer/modules/hotel-crud.js",
    "src/renderer/modules/hotel-list.js",
    "src/renderer/modules/hotel-filters.js",
    "src/renderer/modules/template-ui.js",
    "src/renderer/modules/settings-ui.js",
    "src/renderer/modules/ai-assistant.js",
    "src/renderer/modules/ai-task-formatters.js",
    "src/renderer/modules/ai-task-events.js",
