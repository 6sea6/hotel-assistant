{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": false,
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "skipLibCheck": true
  },
  "include": [
    "src/shared/contracts.js",
    "src/**/*.d.ts",
    "src/renderer/app.module.js",
    "src/renderer/modules/actions.js",
    "src/main/hotel-storage.js",
    "src/renderer/modules/state.js",
    "src/renderer/modules/hotel-crud.js",
    "src/renderer/modules/hotel-list.js",
    "src/renderer/modules/hotel-filters.js",
    "src/renderer/modules/template-ui.js",
    "src/renderer/modules/settings-ui.js",
    "src/main/preload.js",
    "src/main/ipc-handlers/hotel-handlers.js",
    "src/main/ipc-handlers/template-handlers.js",
    "src/main/ipc-handlers/data-handlers.js",
    "src/renderer/modules/ai-task-console.js"
  ],
  "exclude": [
    "node_modules",
    "coverage",
    "dist",
    "dist-*",
    "build",
    "output",
    "state",
    "scraper-data",
    "宾馆比较助手"
  ]
}
