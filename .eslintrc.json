{
  "root": true,
  "env": {
    "browser": true,
    "commonjs": true,
    "es2022": true,
    "node": true
  },
  "extends": ["eslint:recommended"],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "ignorePatterns": [
    "node_modules/",
    "coverage/",
    "dist/",
    "dist-smoke/",
    "build/",
    "output/",
    "state/",
    "scraper-data/",
    "scraper/output/",
    "scraper/state/",
    "scraper/scraper-data/",
    "宾馆比较助手/",
    "hotel-comparison-app/"
  ],
  "rules": {
    "no-empty": ["error", { "allowEmptyCatch": true }],
    "no-inner-declarations": "off",
    "no-useless-escape": "off",
    "no-unused-vars": [
      "warn",
      { "argsIgnorePattern": "^_", "varsIgnorePattern": "^_", "caughtErrorsIgnorePattern": "^_" }
    ],
    "no-console": "off"
  }
}
