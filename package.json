{
  "name": "hotel-comparison-app",
  "version": "8.8.1",
  "description": "宾馆比较终极版应用程序",
  "main": "src/main/main.js",
  "workspaces": [
    "scraper"
  ],
  "scripts": {
    "start": "electron .",
    "build": "node scripts/package/run-build.js",
    "build:win": "node scripts/package/run-build.js",
    "build:nsis": "node scripts/package/run-build.js",
    "sync-app-info": "node scripts/sync-app-info.js",
    "sync-build-assets": "node scripts/sync-build-assets.js",
    "package:smoke": "node scripts/package/smoke-build.js",
    "smoke:data-migration": "node scripts/smoke/data-folder-migration-smoke.js",
    "clean:runtime": "node scripts/cleanup-runtime-artifacts.js",
    "lint": "eslint . --ext .js",
    "typecheck": "tsc -p jsconfig.json --noEmit",
    "format": "prettier --write \"*.json\" \"scraper/*.json\" \"scraper/examples/*.json\" \"src/**/*.js\" \"shared/**/*.js\" \"scripts/**/*.js\" \"tests/**/*.js\" \"scraper/src/**/*.js\" \"scraper/tests/**/*.js\" \"src/renderer/styles.css\" \"src/renderer/manual.html\"",
    "format:check": "prettier --check \"*.json\" \"scraper/*.json\" \"scraper/examples/*.json\" \"src/**/*.js\" \"shared/**/*.js\" \"scripts/**/*.js\" \"tests/**/*.js\" \"scraper/src/**/*.js\" \"scraper/tests/**/*.js\" \"src/renderer/styles.css\" \"src/renderer/manual.html\"",
    "test": "npm run test:app && npm run test:scraper",
    "test:app": "node --test tests/hotel-storage.test.js tests/hotel-normalizer.test.js tests/template-normalizer.test.js tests/hotel-repository.test.js tests/template-repository.test.js tests/template-sync-service.test.js tests/data-transfer-service.test.js tests/data-folder-migration-service.test.js tests/data-folder-migration-fs-integration.test.js tests/id-utils.test.js tests/ipc-handler-registry.test.js tests/ipc-safe-handler.test.js tests/ipc-core-data-safe.test.js tests/shared-compare-app.test.js tests/runtime-paths.test.js tests/service-container.test.js tests/package-scripts.test.js tests/bundled-setup.test.js tests/ai-provider.test.js tests/security-hardening.test.js tests/normalization-writeback.test.js tests/renderer-ai-task-console.test.js tests/renderer-ai-task-logic.test.js tests/renderer-debug-log.test.js tests/renderer-custom-select.test.js tests/renderer-state-ai.test.js tests/renderer-hotel-render-decision.test.js tests/renderer-hotel-list-empty-state.test.js tests/data-folder-manager.test.js tests/hotel-state-helpers.test.js tests/renderer-hotel-crud-incremental.test.js tests/renderer-hotel-derived.test.js tests/renderer-visible-hotels-cache.test.js tests/hotel-virtual-list.test.js tests/renderer-hotel-card-fields.test.js tests/hotel-scroll-memory.test.js tests/hotel-scroll-restore.test.js",
    "test:scraper": "node --test scraper/tests/compare-app-bridge.test.js scraper/tests/cli-modules.test.js scraper/tests/ctrip-list.test.js scraper/tests/ctrip-url-filters.test.js scraper/tests/http-client.test.js scraper/tests/cdp-utils.test.js scraper/tests/task-runner.test.js scraper/tests/batch-edge-worker-pool.test.js scraper/tests/bounded-worker-runner.test.js scraper/tests/prepared-detail-batch-collector.test.js scraper/tests/amap-transit-cache.test.js scraper/tests/perf.test.js scraper/tests/ctrip-scraper-capture-strategy.test.js scraper/tests/edge-settle.test.js scraper/tests/edge-network-modules.test.js scraper/tests/room-logic.test.js scraper/tests/room-type-rules.test.js scraper/tests/amap-geo.test.js scraper/tests/hotel-record.test.js scraper/tests/html-parser.test.js scraper/tests/structured-extractor.test.js scraper/tests/template-loader.test.js scraper/tests/facade-exports.test.js scraper/tests/report-level.test.js scraper/tests/task-writeback.test.js",
    "coverage": "c8 npm test"
  },
  "keywords": [
    "hotel",
    "comparison",
    "electron"
  ],
  "author": "Sea",
  "license": "MIT",
  "devDependencies": {
    "c8": "^11.0.0",
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1",
    "eslint": "^8.57.1",
    "png-to-ico": "^3.0.1",
    "prettier": "^3.8.3",
    "sharp": "^0.34.5",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "electron-store": "^8.1.0"
  },
  "overrides": {
    "fast-uri": "^3.1.2"
  },
  "build": {
    "appId": "com.hotel.comparison.desktop",
    "productName": "宾馆比较终极版",
    "artifactName": "${productName} Setup ${version}.${ext}",
    "directories": {
      "buildResources": "build",
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "package.json",
      "!node_modules/*/{README,readme,readme.md,readme.txt,CHANGELOG,changelog,changelog.md,CHANGELOG.md,NEWS,news,HISTORY,history,LICENSE,license,license.md,license.txt}",
      "!node_modules/@*/*/{README,readme,readme.md,readme.txt,CHANGELOG,changelog,changelog.md,CHANGELOG.md,NEWS,news,HISTORY,history,LICENSE,license,license.md,license.txt}",
      "!node_modules/*/{.github,.travis.yml,.gitignore,.eslintrc,.eslintrc.js,.eslintrc.json,.npmignore}",
      "!node_modules/@*/*/{.github,.travis.yml,.gitignore,.eslintrc,.eslintrc.js,.eslintrc.json,.npmignore}",
      "!node_modules/*/test/**/*",
      "!node_modules/@*/*/test/**/*",
      "!node_modules/*/tests/**/*",
      "!node_modules/@*/*/tests/**/*",
      "!node_modules/*/__tests__/**/*",
      "!node_modules/@*/*/__tests__/**/*",
      "!node_modules/*/src/**/*",
      "!node_modules/@*/*/src/**/*",
      "!node_modules/*/example/**/*",
      "!node_modules/@*/*/example/**/*",
      "!node_modules/*/examples/**/*",
      "!node_modules/@*/*/examples/**/*",
      "!node_modules/*/demo/**/*",
      "!node_modules/@*/*/demo/**/*",
      "!node_modules/*/*.ts",
      "!node_modules/@*/*/*.ts",
      "!node_modules/*/*.map",
      "!node_modules/@*/*/*.map",
      "!node_modules/*/{.editorconfig,.gitkeep,.jshintrc,.npmignore,.travis.yml}",
      "!node_modules/*/docs/**/*",
      "!node_modules/@*/*/docs/**/*",
      "!node_modules/*/doc/**/*",
      "!node_modules/@*/*/doc/**/*",
      "!node_modules/*/{Makefile,makefile,Gruntfile.js,Gulpfile.js,gulpfile.js}",
      "!node_modules/*/{karma.conf.js,webpack.config.js,rollup.config.js,.babelrc,.babelrc.js,.babelrc.json}",
      "!宾馆比较助手/**/*",
      "!hotel-comparison-app/**/*",
      "!devtools/**/*",
      "!logs/**/*",
      "!scripts/analyze_perf.py",
      "!output/**/*",
      "!state/**/*",
      "!scraper-data/**/*",
      "!scraper/logs/**/*",
      "!scraper/tests/**/*",
      "!scraper/devtools/**/*",
      "!scraper/scripts/analyze_perf.py",
      "!scraper/output/**/*",
      "!scraper/state/**/*",
      "!scraper/scraper-data/**/*",
      "!**/*.jsonl",
      "!**/collect_perf.jsonl",
      "!**/perf_log.py",
      "!**/edge-profile/**/*",
      "!**/raw-pages/**/*",
      "!**/hotel-data.json",
      "!**/*api*key*",
      "!**/*.md",
      "!**/*.ts",
      "!**/*.map"
    ],
    "extraResources": [
      {
        "from": "shared/compare-app",
        "to": "shared/compare-app",
        "filter": [
          "**/*.js"
        ]
      }
    ],
    "extraFiles": [
      {
        "from": "build/icon.ico",
        "to": "icon.ico"
      },
      {
        "from": "build/uninstallerIcon.ico",
        "to": "uninstallerIcon.ico"
      }
    ],
    "asar": true,
    "win": {
      "icon": "icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "signAndEditExecutable": true
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "differentialPackage": false,
      "deleteAppDataOnUninstall": false,
      "installerIcon": "icon.ico",
      "uninstallerIcon": "uninstallerIcon.ico",
      "installerHeaderIcon": "icon.ico",
      "installerSidebar": "installerSidebar.bmp",
      "uninstallerSidebar": "installerSidebar.bmp",
      "shortcutName": "宾馆比较终极版",
      "uninstallDisplayName": "宾馆比较终极版",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "installerLanguages": [
        "zh_CN"
      ],
      "displayLanguageSelector": false,
      "unicode": true
    },
    "electronDist": null,
    "electronVersion": "42.0.1",
    "electronLanguages": [
      "zh-CN",
      "en-US"
    ],
    "compression": "maximum",
    "removePackageScripts": true,
    "removePackageKeywords": true,
    "nodeGypRebuild": false,
    "buildDependenciesFromSource": false
  }
}
